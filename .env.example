# VLM API Keys
# Copy this file to .env and fill in keys ONLY if you want to use a remote
# provider. By default the pipeline runs the local Unsloth/Qwen specialist
# and needs no keys — leave this file empty or unset and everything works.

# OpenAI (gpt-4o, o1, etc.) — only needed if you set the provider to openai
OPENAI_API_KEY=your_openai_key_here

# Anthropic (claude-3-5-sonnet, etc.) — only needed if you set the provider to anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Custom Ollama URL
# OLLAMA_BASE_URL=http://localhost:11434/api/generate
